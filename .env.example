# ──────────────────────────────────────────────────────────────────
# BNB Hack AI Trading Agent — Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────

# ── Wallet (required) ──────────────────────────────────────────────
# Password used to encrypt the local keystore (~/.bnbagent/wallets/)
# Pick something strong — this protects your private key on disk.
WALLET_PASSWORD=your-secure-password-here

# Hex private key (without 0x prefix).
# Only needed on FIRST RUN — after that the keystore is loaded from disk.
# Alternative: set WALLET_ADDRESS to select an existing keystore.
PRIVATE_KEY=

# Optional: specify which keystore address to load (when you have multiple)
# WALLET_ADDRESS=0xYourWalletAddress

# ── CMC API Key (required) ─────────────────────────────────────────
# Pro tier recommended — rate limits are 1000+ calls/min on Pro.
# Free tier: 300 calls/min (still works, but tighter).
CMC_API_KEY=

# ── LLM API Key (recommended) ────────────────────────────────────
# DeepSeek API key for regime classification. Without this, the agent
# runs on "neutral" regime forever — still trades, just less aggressive.
# DeepSeek API is OpenAI-compatible, sign up at platform.deepseek.com
DEEPSEEK_API_KEY=

# ── Agent state directory (optional) ───────────────────────────────
# Where the agent stores portfolio_state.json and trade_log.json.
# Default: ./state/ relative to this repo.
# AGENT_STATE_DIR=/path/to/state

# ── x402 payment limits (optional) ─────────────────────────────────
# Override the per-call and session spending caps for CMC API payments.
# Values in base units of the BSC U-token (6 decimals).
# Defaults: 1 U per call, 50 U session budget.
# X402_MAX_VALUE_PER_CALL=1000000
# X402_SESSION_BUDGET=50000000

# ── Logging (optional) ─────────────────────────────────────────────
# Set to DEBUG for verbose output during troubleshooting.
# LOG_LEVEL=INFO
